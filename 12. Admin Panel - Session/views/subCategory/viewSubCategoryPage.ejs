<%- include('../header')%>

    <style>
        .admin-container {
            padding: 1.5rem;
            background-color: #f8f9fa;
            min-height: 100vh;
        }

        .table-card {
            border-radius: 12px;
            overflow: hidden;
            border: none;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
        }

        /* Header styling */
        .custom-table thead {
            background-color: #212529;
            color: #ffffff;
        }

        .custom-table th {
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            padding: 15px !important;
            border: none;
        }

        /* Row styling */
        .custom-table td {
            padding: 10px 15px !important;
            vertical-align: middle;
            border-bottom: 1px solid #eee;
            font-size: 0.95rem;
        }

        /* Fixed Image Container */
        .img-box {
            width: 55px;
            height: 55px;
            margin: 0 auto;
            border-radius: 8px;
            overflow: hidden;
            border: 1px solid #e0e0e0;
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .img-box img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        /* Button Tweak */
        .action-btns .btn {
            padding: 6px 12px;
            font-size: 0.85rem;
            border-radius: 6px;
            transition: all 0.2s;
        }

        .action-btns .btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        }

        .cat-label {
            font-size: 0.75rem;
            color: #6c757d;
            display: block;
            margin-bottom: -2px;
        }
    </style>

    <div class="admin-container">
        <div class="d-flex justify-content-between align-items-center mb-4 px-2">
            <div>
                <h4 class="fw-bold m-0 text-dark">Sub-Categories</h4>
                <small class="text-muted">Organize your product hierarchy</small>
            </div>
            <button class="btn btn-dark btn-sm px-4 rounded-pill shadow-sm">
                <i class="fas fa-plus me-2"></i>New Sub-Category
            </button>
        </div>

        <div class="card table-card">
            <div class="table-responsive">
                <table class="table custom-table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="text-center" style="width: 70px">#</th>
                            <th>Parent Category</th>
                            <th>Sub-Category Name</th>
                            <th class="text-center" style="width: 150px">Image</th>
                            <th class="text-center" style="width: 220px">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% allSubcategory.forEach((row, index)=> { %>
                            <tr>
                                <td class="text-center text-muted fw-bold">
                                    <%= index + 1 %>
                                </td>

                                <td>
                                    <span class="cat-label">Main Category</span>
                                    <div class="fw-bold text-primary">
                                        <%= row.category_id.category_name %>
                                    </div>
                                </td>

                                <td>
                                    <span class="cat-label">Sub Classification</span>
                                    <div class="fw-semibold text-dark">
                                        <%= row.SubCategory_name %>
                                    </div>
                                </td>

                                <td class="text-center">
                                    <div class="img-box shadow-sm">
                                        <img src="/<%= row.category_id.category_image %>"
                                            onerror="this.src='/uploads/default-avatar.png'" alt="Category">
                                    </div>
                                </td>

                                <td>
                                    <div class="d-flex justify-content-center gap-2 action-btns">
                                        <a href="/subCategory/editSubCategory/<%= row._id %>"
                                            class="btn btn-primary shadow-sm">
                                            <i class="fas fa-edit me-1"></i> Edit
                                        </a>

                                        <a href="/subCategory/deleteSubCategory/<%= row._id %>"
                                            class="btn btn-danger shadow-sm"
                                            onclick="return confirm('Delete this sub-category?')">
                                            <i class="fas fa-trash me-1"></i> Delete
                                        </a>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <%- include('../footer')%>