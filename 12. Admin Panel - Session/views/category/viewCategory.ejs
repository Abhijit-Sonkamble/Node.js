<%- include('../header')%>

    <style>
        .admin-container {
            padding: 1.5rem;
            background-color: #f8f9fa;
            min-height: 100vh;
        }

        .table-card {
            border-radius: 12px;
            overflow: hidden;
            border: none;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
        }

        /* Professional Table Header */
        .custom-table thead {
            background-color: #212529;
            color: #ffffff;
        }

        .custom-table th {
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            padding: 15px !important;
            border: none;
        }

        /* Clean Rows */
        .custom-table td {
            padding: 12px 15px !important;
            vertical-align: middle;
            border-bottom: 1px solid #eee;
            font-size: 0.95rem;
        }

        /* Centered Image Container */
        .img-box {
            width: 60px;
            height: 60px;
            margin: 0 auto;
            border-radius: 8px;
            overflow: hidden;
            border: 1px solid #e0e0e0;
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: transform 0.2s;
        }

        .img-box:hover {
            transform: scale(1.05);
        }

        .img-box img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        /* Action Buttons */
        .action-btns .btn {
            padding: 6px 14px;
            font-size: 0.85rem;
            border-radius: 6px;
            font-weight: 500;
            transition: all 0.2s;
        }

        .btn-edit {
            background-color: #4e73df;
            border: none;
            color: white;
        }

        .btn-delete {
            background-color: #e74a3b;
            border: none;
            color: white;
        }

        .action-btns .btn:hover {
            opacity: 0.9;
            transform: translateY(-1px);
        }
    </style>

    <div class="admin-container">
        <div class="d-flex justify-content-between align-items-center mb-4 px-2">
            <div>
                <h4 class="fw-bold m-0 text-dark">Category Management</h4>
                <p class="text-muted small mb-0">Manage top-level store categories</p>
            </div>
            <a href="/category/addCategoryPage" class="btn btn-dark btn-sm px-4 rounded-pill shadow-sm">
                <i class="fas fa-plus me-2"></i> Add Category
            </a>
        </div>

        <div class="card table-card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table custom-table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th class="text-center" style="width: 80px">#</th>
                                <th class="text-center" style="width: 120px">Preview</th>
                                <th class="ps-4">Category Name</th>
                                <th class="text-center" style="width: 250px">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% allCategories.forEach((row, index)=> { %>
                                <tr>
                                    <td class="text-center text-muted fw-bold">
                                        <%= index + 1 %>
                                    </td>

                                    <td class="text-center">
                                        <div class="img-box shadow-sm">
                                            <img src="/<%= row.category_image %>"
                                                onerror="this.src='/uploads/default-avatar.png'" alt="Category">
                                        </div>
                                    </td>

                                    <td class="ps-4">
                                        <div class="fw-bold text-dark" style="font-size: 1.05rem;">
                                            <%= row.category_name %>
                                        </div>
                                        <small class="text-muted">ID: <%= row._id.toString().slice(-6) %></small>
                                    </td>

                                    <td>
                                        <div class="d-flex justify-content-center gap-2 action-btns">
                                            <a href="/category/editCategory/<%= row._id %>"
                                                class="btn btn-edit shadow-sm">
                                                <i class="fas fa-edit me-1"></i> Edit
                                            </a>

                                            <a href="/category/deleteCategory/<%= row._id %>"
                                                class="btn btn-delete shadow-sm"
                                                onclick="return confirm('Are you sure you want to delete this category?')">
                                                <i class="fas fa-trash me-1"></i> Delete
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <%- include('../footer')%>