<%- include('../header')%>

    <style>
        .product-admin-container {
            padding: 1.5rem;
            background-color: #f8f9fa;
            min-height: 100vh;
        }

        .table-card {
            border-radius: 12px;
            overflow: hidden;
            border: none;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
        }

        .custom-table thead {
            background-color: #212529;
            color: #ffffff;
        }

        .custom-table th {
            font-size: 0.8rem;
            text-transform: uppercase;
            padding: 15px !important;
            border: none;
            vertical-align: middle;
        }

        .custom-table td {
            padding: 10px 15px !important;
            vertical-align: middle;
            border-bottom: 1px solid #eee;
        }

        /* Fixed Image Handling */
        .img-cell {
            width: 80px;
            /* Ensures the column doesn't wobble */
            text-align: center;
        }

        .img-wrapper {
            width: 50px;
            height: 50px;
            margin: 0 auto;
            /* Centers the box in the cell */
            border-radius: 8px;
            overflow: hidden;
            border: 1px solid #e0e0e0;
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s ease;
        }

        .img-wrapper:hover {
            transform: scale(1.1);
            border-color: #0d6efd;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        }

        .img-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            /* Prevents stretching */
            display: block;
        }

        /* Typography & Badges */
        .price-tag {
            font-weight: 700;
            color: #333;
        }

        .stock-badge {
            font-size: 0.7rem;
            padding: 4px 8px;
            border-radius: 50px;
            background: #e9ecef;
            font-weight: 600;
            white-space: nowrap;
        }

        .desc-cell {
            max-width: 150px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            font-size: 0.85rem;
            color: #666;
        }
    </style>

    <div class="product-admin-container">
        <div class="d-flex justify-content-between align-items-center mb-4 px-2">
            <h4 class="fw-bold m-0">Inventory Manager</h4>
            <button class="btn btn-dark btn-sm rounded-pill px-4">
                <i class="fas fa-plus me-2"></i>Add Product
            </button>
        </div>

        <div class="card table-card">
            <div class="table-responsive">
                <table class="table custom-table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th style="width: 50px">#</th>
                            <th>Product Details</th>
                            <th>Hierarchy</th>
                            <th>Pricing</th>
                            <th>Stock</th>
                            <th>Description</th>
                            <th class="text-center">Product</th>
                            <th class="text-center">Category</th>
                            <th class="text-center" style="width: 120px">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% allProducts.forEach((row, index)=> { %>
                            <tr>
                                <td class="text-muted fw-bold">
                                    <%= index + 1 %>
                                </td>

                                <td>
                                    <div class="fw-bold text-dark">
                                        <%= row.title %>
                                    </div>
                                    <small class="text-uppercase text-muted" style="font-size: 0.7rem;">
                                        SKU: <%= row._id.toString().slice(-5) %>
                                    </small>
                                </td>

                                <td>
                                    <div class="text-primary fw-semibold small">
                                        <%= row.category_id.category_name %>
                                    </div>
                                    <div class="text-muted" style="font-size: 0.75rem;">
                                        <%= row.subCategory_id.SubCategory_name %> / <%=
                                                row.extraCategory_id.extraCategory_name %>
                                    </div>
                                </td>

                                <td>
                                    <div class="price-tag">₹<%= row.price %>
                                    </div>
                                    <del class="text-muted small">₹<%= row.old_price %></del>
                                </td>

                                <td>
                                    <span class="stock-badge">
                                        <i class="fas fa-box-open me-1"></i>
                                        <%= row.stock %>
                                    </span>
                                </td>

                                <td>
                                    <div class="desc-cell" title="<%= row.description %>">
                                        <%= row.description %>
                                    </div>
                                </td>

                                <td class="img-cell">
                                    <div class="img-wrapper shadow-sm">
                                        <img src="/<%= row.product_image %>" onerror="this.src='/uploads/default.png'">
                                    </div>
                                </td>

                                <td class="img-cell">
                                    <div class="img-wrapper shadow-sm">
                                        <img src="/<%= row.category_id.category_image %>"
                                            onerror="this.src='/uploads/default.png'">
                                    </div>
                                </td>

                                <td>
                                    <div class="d-flex justify-content-center gap-2 action-btns">
                                        <a href="/products/editProductsPage/<%= row._id %>"
                                            class="btn btn-light btn-sm border">
                                            <i class="fas fa-edit text-primary"></i>
                                        </a>
                                        <a href="/products/deleteProducts/<%= row._id %>"
                                            class="btn btn-light btn-sm border"
                                            onclick="return confirm('Delete this product?')">
                                            <i class="fas fa-trash text-danger"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <%- include('../footer')%>