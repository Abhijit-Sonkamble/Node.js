    <script>
        const categoryField = document.getElementById("category_id");
        const subCategoryField = document.getElementById("subCategory_id");
        const extraCategoryField = document.getElementById("extraCategory_id");

        const allSubCategoryData = <%- JSON.stringify(allSubCategory) %>;
        const allExtraCategoryData = <%- JSON.stringify(allExtraCategory) %>;

        // CATEGORY CHANGE
        categoryField.addEventListener("change", function () {

            const selectedCategory = this.value;

            subCategoryField.innerHTML = "<option value=''>Select Sub Category</option>";
            extraCategoryField.innerHTML = "<option value=''>Select Extra Category</option>";

            if (!selectedCategory) return;

            const filteredSubCategories = allSubCategoryData.filter(sub =>
                sub.category_id.toString() === selectedCategory
            );

            filteredSubCategories.forEach(sub => {
                subCategoryField.innerHTML += `
                <option value="${sub._id}">
                    ${sub.SubCategory_name}
                </option>
            `;
            });
        });

        // SUB CATEGORY CHANGE
        subCategoryField.addEventListener("change", function () {

            const selectedSubCategory = this.value;

            extraCategoryField.innerHTML = "<option value=''>Select Extra Category</option>";

            if (!selectedSubCategory) return;

            const filteredExtraCategories = allExtraCategoryData.filter(extra =>
                extra.subCategory_id.toString() === selectedSubCategory
            );

            filteredExtraCategories.forEach(extra => {
                extraCategoryField.innerHTML += `
                <option value="${extra._id}">
                    ${extra.extraCategory_name}
                </option>
            `;
            });
        });
    </script>

    </body>

    </html>