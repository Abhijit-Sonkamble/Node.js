<%- include('../header')%>

    <style>
        /* Compact Table Styling */
        .admin-table-card {
            border-radius: 12px;
            overflow: hidden;
            border: none;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08) !important;
        }

        .table thead {
            background-color: #1a1a1a;
            color: #ffffff;
        }

        .table th {
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            font-weight: 600;
            padding: 15px !important;
            border: none;
        }

        .table td {
            padding: 12px 15px !important;
            /* Tighter padding */
            vertical-align: middle;
            font-size: 0.95rem;
            border-bottom: 1px solid #f0f0f0;
        }

        /* Image Wrapper to prevent layout jumping */
        .cat-img-box {
            width: 55px;
            height: 55px;
            border-radius: 8px;
            overflow: hidden;
            border: 1px solid #eee;
            display: inline-block;
            margin: 0 auto;
        }

        .cat-img-box img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        /* Action Buttons Polish */
        .action-group {
            display: flex;
            justify-content: center;
            gap: 8px;
            /* Controlled spacing */
        }

        .btn-action {
            padding: 6px 12px;
            font-size: 0.8rem;
            border-radius: 6px;
            font-weight: 500;
            transition: transform 0.2s;
        }

        .btn-action:hover {
            transform: translateY(-2px);
        }

        .text-truncate-custom {
            max-width: 200px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        /* Breadcrumb look for category path */
        .category-path {
            font-size: 0.75rem;
            color: #6c757d;
            margin-top: 2px;
        }
    </style>

    <div class="container-fluid py-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="fw-bold text-dark m-0">Extra Categories Management</h4>
            <a href="/extraCategory/add" class="btn btn-dark btn-sm px-3 shadow-sm">
                <i class="fas fa-plus me-1"></i> Add New
            </a>
        </div>

        <div class="card admin-table-card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th class="text-center" style="width: 60px">#</th>
                                <th>Category Hierarchy</th>
                                <th>Extra Category Name</th>
                                <th class="text-center">Category Image</th>
                                <th class="text-center" style="width: 200px">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% allExtracategory.forEach((row, index)=> { %>
                                <tr>
                                    <td class="text-center text-muted fw-bold">
                                        <%= index + 1 %>
                                    </td>

                                    <td>
                                        <div class="fw-bold text-primary">
                                            <%= row.category_id.category_name %>
                                        </div>
                                        <div class="category-path">
                                            <i class="fas fa-level-up-alt fa-rotate-90 me-1"></i>
                                            <%= row.subCategory_id.SubCategory_name %>
                                        </div>
                                    </td>

                                    <td>
                                        <span class="fw-semibold text-dark text-truncate-custom d-block">
                                            <%= row.extraCategory_name %>
                                        </span>
                                    </td>

                                    <td class="text-center">
                                        <div class="cat-img-box shadow-sm">
                                            <img src="/<%= row.category_id.category_image %>"
                                                onerror="this.src='/uploads/default-avatar.png'" alt="Category">
                                        </div>
                                    </td>

                                    <td>
                                        <div class="action-group">
                                            <a href="/extraCategory/editExtraCategoryPage/<%= row._id %>"
                                                class="btn btn-primary btn-action shadow-sm">
                                                <i class="fas fa-edit me-1"></i> Edit
                                            </a>
                                            <a href="/extraCategory/deleteExtraCategory/<%= row._id %>"
                                                class="btn btn-danger btn-action shadow-sm"
                                                onclick="return confirm('Delete this category?')">
                                                <i class="fas fa-trash me-1"></i> Delete
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <%- include('../footer')%>